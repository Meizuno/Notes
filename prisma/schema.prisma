generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("NUXT_DATABASE_URL")
  extensions = [pg_trgm]
}

// Shared notes vault: any authenticated user can read, create, edit, or
// delete any PUBLIC/PROTECTED note. PRIVATE notes are visible and mutable
// only to their creator, so `user_id` is both the creator stamp and the
// PRIVATE-tier ACL boundary (enforced by the scoped data-access in
// server/utils/notes.ts).
//
// Notes are grouped by `folder` (slash-separated path). Folders are
// implicit — never stored as rows; the sidebar tree is derived from
// the unique prefixes across all non-deleted notes.
model Note {
  // UUID PK — generated client-side by Prisma so the id is known
  // before the row hits the DB (useful for optimistic creates +
  // sharable URLs that aren't enumerable like autoincrement ints).
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String
  title       String  @db.VarChar(300)
  folder      String? @db.VarChar(500)
  // Optional one- or two-sentence summary surfaced in list / search
  // contexts. Stored on the note row itself rather than derived from
  // the first paragraph of content so the author keeps explicit
  // control over what gets shown.
  description String? @db.VarChar(500)
  content     String  @default("") @db.Text
  // Visibility tier. Standard web-auth model:
  //   PUBLIC    — anyone can read (incl. anonymous visitors)
  //   PROTECTED — any authenticated user can read (default — the
  //               shared-workspace baseline)
  //   PRIVATE   — only the creator (matched against `user_id`) can
  //               read
  // Write access (PUT/POST/DELETE) always requires auth; this enum
  // gates *read* access only.
  visibility NoteVisibility @default(PROTECTED)
  // "Anyone with the link can read" — orthogonal to `visibility`. When
  // true, the note is readable by its URL (incl. anonymous) even if its
  // tier is PROTECTED/PRIVATE, but it still does NOT appear in other
  // users' tree / graph / search (listing keeps using the tier filter).
  // Write access is unaffected — only the creator / shared-workspace can
  // mutate. PUBLIC notes are shared by definition, so this is forced true
  // for them (see the service + the backfill migration).
  is_shared  Boolean  @default(false)
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([user_id])
  @@index([is_deleted])
  @@index([folder])
  @@index([visibility])
  @@index([title(ops: raw("gin_trgm_ops"))],   type: Gin)
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("notes")
}

// Visibility tier for Note (see `Note.visibility`). Stored as a
// Postgres enum (`@@map`ed to `note_visibility`) so adding new tiers
// later only requires an ALTER TYPE migration rather than a string
// column rewrite.
enum NoteVisibility {
  PRIVATE
  PROTECTED
  PUBLIC

  @@map("note_visibility")
}
